{
  "name": "nitron",
  "version": "1.0.1",
  "description": "HTML/CSS/JS to Android APK builder",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "bin": {
    "nitron": "./dist/cli.js"
  },
  "files": [
    "dist",
    "template",
    "vendor"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepare-template": "node scripts/prepare-template.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "android",
    "apk",
    "html",
    "css",
    "javascript",
    "mobile",
    "webview",
    "npm",
    "build-tool"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "browser-sync": "^3.0.4",
    "commander": "^13.1.0",
    "jszip": "^3.10.1",
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/browser-sync": "^2.29.1",
    "@types/node": "^22.0.0",
    "@types/prompts": "^2.4.9",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0"
  }
}
